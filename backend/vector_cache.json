3574361652135849,"371":0.08642978966236115,"372":0.05471722409129143,"373":0.00017500616377219558,"374":-0.02790907397866249,"375":0.018237026408314705,"376":-0.02619817852973938,"377":-0.06079142168164253,"378":-0.029699422419071198,"379":0.015643760561943054,"380":0.05371791869401932,"381":0.06997169554233551,"382":0.05417552590370178,"383":-0.07044835388660431}},{"id":1,"text":"INOVFABLAB é uma oficina de fabricação digital onde podemos usar máquinas de corte, impressoras 3D, para trabalhar em vários materiais: plástico, madeira, papelão, vinil, para criar qualquer tipo de objeto através de desenho assistido por computador ou eletrônica. Mas o Fab Lab também é um local de troca de habilidades técnicas.\nO INOVFABLAB é um espaço permanente: aberto a todos, oferece a oportunidade de criar objetos, compartilhar suas habilidades e aprender com os mediadores do Fab Lab e outros usuários.\nO treinamento no Fab Lab é baseado em projetos e compartilhamento de conhecimento: você deve participar da capitalização do conhecimento e da instrução de outros usuários.\nLer os termos e condições do FabLab \nLocalizado na Universidade Santa Cecilia em Santos SP\nO QUE É UM FABLAB?\nUm fablab (do inglês \"Fabrication Laboratory\"), é um laboratório de fabricação digital que nasceu com o principal intuito de aproximar a comunidade acadêmica a equipamentos de caráter semi-industrial. A ideia se expandiu e atualmente ele é utilizado por todos os públicos, ou seja, qualquer pessoa pode ter acesso a um fablab.\nO fablab foi originalmente criado no Instituto de Tecnologia de Massachusetts (MIT). Nele, estudantes, pesquisadores, educadores, inventores podem ampliar seus horizontes de ideação e por em prática todo seu potencial de inovação e criação, o fablab é presente em mais de 1500 cidades espalhadas por todo o mundo.\nSOBRE O INOVFABLAB\nO InovFabLab é um laboratório de fabricação digital da Universidade Santa Cecília, também utilizado principalmente na troca de conhecimento. Atrás do site de gerenciamento do laboratório, o FabManager, ao se cadstrar, é possível visualizar todos os projetos já criados e ainda colocar o seu próprio projetos para exposição. O InovFabLab além de ser um espaço para desenvolver projetos, é principalmente um lugar para se ensinar e aprender.\nDentro do InovFabLab, é incentivada a cultura DIY (Do It Yourself, do inglês, faça você mesmo), ou seja,","source":"Arquivo: inovfablab.txt","vector":{"0":-0.03336339816451073,"1":-0.04903785511851311,"2":-0.08761077374219894,"3":-0.0470932200551033,"4":-0.055730562657117844,"5":-0.04798128083348274,"6":-0.08182317763566971,"7":0.08845842629671097,"8":-0.043995145708322525,"9":0.1096201241016388,"10":0.014827764593064785,"11":-0.061058033257722855,"12":0.013496522791683674,"13":0.027991261333227158,"14":-0.028963789343833923,"15":-0.015636347234249115,"16":0.00010419574391562492,"17":-0.010039583779871464,"18":0.01481142733246088,"19":0.022011402994394302,"20":0.05476955696940422,"21":-0.09281328320503235,"22":-0.04509984701871872,"23":-0.022457458078861237,"24":-0.014985053800046444,"25":0.01576182432472706,"26":-0.01946289651095867,"27":0.0015039739664644003,"28":-0.08753081411123276,"29":-0.043108776211738586,"30":-0.04753996431827545,"31":0.12353552877902985,"32":0.09703143686056137,"33":-0.001612618681974709,"34":0.06916772574186325,"35":0.03070669062435627,"36":0.1112077534198761,"37":-0.02421700768172741,"38":-0.046506915241479874,"39":0.018732143566012383,"40":-0.0882757231593132,"41":-0.0031126581598073244,"42":0.005360412877053022,"43":-0.03708042576909065,"44":0.003569747321307659,"45":-0.05142701789736748,"46":0.043656498193740845,"47":0.0038700809236615896,"48":-0.03654167801141739,"49":0.02655169554054737,"50":-0.07073730230331421,"51":-0.04883311688899994,"52":-0.03632007911801338,"53":0.022753503173589706,"54":-0.026402652263641357,"55":0.024297168478369713,"56":0.05015791207551956,"57":0.04965972155332565,"58":0.011309614405035973,"59":0.029341574758291245,"60":-