07187235355,"358":-0.05219827592372894,"359":0.03480805829167366,"360":0.1429520547389984,"361":-0.03095329739153385,"362":-0.007126283831894398,"363":-0.05835215002298355,"364":0.022114289924502373,"365":0.02045084536075592,"366":0.038880232721567154,"367":0.06500372290611267,"368":0.05675877630710602,"369":0.015656601637601852,"370":-0.04530596733093262,"371":0.01268908940255642,"372":0.0065356409177184105,"373":-0.05430572107434273,"374":-0.05429675057530403,"375":-0.04305446147918701,"376":0.10686444491147995,"377":0.05327901989221573,"378":-0.027256052941083908,"379":-0.004543140530586243,"380":0.05364014208316803,"381":0.05185442790389061,"382":0.016102278605103493,"383":-0.03225356340408325}},{"id":2,"text":"ha da escola. Nós damos um \"beijo\" na sociedade, mas traímos o que Jesus nos ensinou.\n- A Dor de Jesus: Jesus o chama de \"Amigo\".\n- Mostre o quanto o nosso pecado oculto e nossas justificativas entristecem a Deus.\n## 4. O Fim da Linha: Remorso vs. Arrependimento\n- O Desespero (Mateus 27:3-5):\n- -Judas percebe a gravidade do que fez.\n- -Ele devolve as moedas.\n- -Ele tenta consertar do seu próprio jeito.\n- A Diferença Crucial:\n- -Judas sentiu remorso (culpa, peso, vergonha das consequências), mas não arrependimento (correr de volta para os braços do Pai, como Pedro fez).\n- -O remorso fez Judas tirar a própria vida; o arrependimento teria trazido perdão.\n- Aplicação: Muitos adolescentes e jovens carregam uma culpa paralisante por falharem em segredo. Eles se sentem um \"Judas\" e acham que Deus não os quer mais. Mas o convite de Deus não é para a condenação, é para o perdão.\n## 5. Conclusão e Apelo: A Obra da Cruz\n- O Evangelho: Lembre-os da essência da nossa fé. Jesus se entregou para ser preso ali no Getsêmani, foi crucificado e pagou o preço por TODAS as nossas traições e pecados ocultos. Ao terceiro dia, Ele ressuscitou, provando que nem a morte nem os nossos maiores erros têm a palavra final. Ele subiu aos céus e a grande promessa é que Ele voltará para buscar uma igreja (uma noiva) verdadeira, não de aparências.\n- Apelo: \"Quantos aqui estão cansados de usar máscaras? Quantos estão sustentando um personagem de 'bom cristão', mas sabem que estão dando 'beijos de traição' em Jesus no dia a dia? Hoje é dia de largar o remorso, abraçar o arrependimento e correr para a graça d'Ele.\"","source":"Arquivo: 1776916078863-181422532.pdf.md","vector":{"0":-0.042114127427339554,"1":0.029008740559220314,"2":0.00633099302649498,"3":-0.0678989589214325,"4":-0.030115175992250443,"5":-0.007296034600585699,"6":-0.018345752730965614,"7":0.06196995824575424,"8":0.0932607352733612,"9":0.0901874452829361,"10":0.0934363305568695,"11":-0.04467712715268135,"12":0.04525746405124664,"13":-0.0035349398385733366,"14":0.02951090969145298,"15":-0.0016207554144784808,"16":-0.012807650491595268,"17":0.04933563992381096,"18":-0.02466289885342121,"19":0.05650729313492775,"20":0.11641696840524673,"21":-0.036503251641988754,"22":-0.06219024956226349,"23":0.011002999730408192,"24":-0.07757701724767685,"25":0.07102398574352264,"26":-0.005445968359708786,"27":0.0011318308534100652,"28":-0.11480163037776947,"29":-0.040756888687610626,"30":-0.06711413711309433,"31":0.035697005689144135,"32":0.06543538719415665,"33":-0.06477898359298706,"34":-0.050275545567274094,"35":0.05180526152253151,"36":0.07105544954538345,"37":-0.012600382789969444,"38":-0.05638843774795532,"39":0.018375061452388763,"40":-0.029498787596821785,"41":0.09602897614240646,"42":-0.018549514934420586,"43":-0.016091326251626015,"44":0.027539648115634918,"45":-0.09354112297296524,"46":0.05409850552678108,"47":0.023249734193086624,"48":0.054475244134664536,"49":-0.06000852957367897,"50":-0.05829682573676109,"51":0.06612507253885269,"52":-0.09479385614395142,"53":0.04625197872519493,"54":-0.037247899919748306,"55":-0.037631504237651825,"56":-0.042507193982601166,"57":-0.044658113270998,"58":0.03632526472210884,"59":0.009490427561104298,"60":-0.05792861804366112,"61":-0.022810