generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./inovfablab.db" // Nome do novo arquivo de banco
}

// 1. Tabela de Usuários
model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  ra           String?       @unique // Opcional, pois admin pode não ter RA
  password     String
  role         String        @default("ALUNO") // Pode ser "ALUNO", "PROFESSOR" ou "ADMIN"
  appointments Appointment[] // Relação: Um usuário pode ter vários agendamentos
}

// 2. Tabela de Equipamentos 
model Equipment {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  imagePath    String?       // Aqui vai o caminho da foto (ex: /uploads/bambu.jpg)
  status       String        @default("DISPONÍVEL") // "DISPONÍVEL", "MANUTENÇÃO", etc.
  appointments Appointment[] // Relação: Um equipamento pode ter vários agendamentos
}

// 3. Tabela de Agendamentos (Atualizada com a regra de aprovação)
model Appointment {
  id          Int       @id @default(autoincrement())
  date        String    // Ex: "2026-04-20"
  time        String    // Ex: "14:00"
  status      String    @default("PENDENTE") // "PENDENTE", "APROVADO", "RECUSADO"
  
  // Relacionando com Usuário
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  
  // Relacionando com Equipamento
  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
}